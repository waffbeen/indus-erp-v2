# =============================================================================
# Indus ERP v2 — Environment variables
# Copy this file to .env (root) and fill in your own values.
# Each app also has its own .env.example with app-specific vars.
# NEVER commit .env files.
# =============================================================================

# ----- Database (Neon Postgres) -----
# Sign up at https://neon.tech, create a project, copy the pooled connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

# ----- API (apps/api) -----
API_PORT=4000
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

# JWT secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace-me-with-48-byte-random
JWT_REFRESH_SECRET=replace-me-with-a-different-48-byte-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ----- Web (apps/web) -----
NEXT_PUBLIC_API_URL=http://localhost:4000

# ----- AI assistant ("Ask your ERP") -----
# These are PLATFORM-LEVEL fallback keys. Each tenant can instead store their OWN
# key under Settings -> AI Assistant (stored encrypted in the DB — no redeploy).
# Supported providers: gemini | openai | anthropic. Leave all blank to disable the
# assistant gracefully (everything else in the app still works).
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Default provider when only platform keys are set (gemini | openai | anthropic).
AI_DEFAULT_PROVIDER=gemini
# Optional model overrides (else: gemini-2.0-flash / gpt-4o-mini / claude-opus-4-8).
GEMINI_MODEL=
ANTHROPIC_MODEL=
# Secret used to encrypt per-tenant API keys at rest. Falls back to JWT_ACCESS_SECRET.
AI_KEY_SECRET=

# ----- Email -----
# Two transports: SMTP (preferred when SMTP_HOST is set) or Resend. If neither is
# set, mail sends are graceful no-ops. From-address used by both:
MAIL_FROM=Indus ERP <onboarding@resend.dev>
# SMTP — e.g. your existing mailbox. SMTP_SECURE=true for port 465, false for 587.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Resend (alternative to SMTP)
RESEND_API_KEY=

# ----- Optional: Background jobs (later phase) -----
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
