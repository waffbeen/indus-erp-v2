DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
API_PORT=4000
API_ORIGIN=http://localhost:4000
WEB_ORIGIN=http://localhost:3000

JWT_ACCESS_SECRET=replace-me-with-48-byte-random
JWT_REFRESH_SECRET=replace-me-with-a-different-48-byte-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

NODE_ENV=development
LOG_LEVEL=debug
